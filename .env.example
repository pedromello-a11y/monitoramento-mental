# Copie este arquivo para .env e preencha os valores.
# Para rodar localmente sem banco (só para ver o formulário /checkin-web),
# deixe DATABASE_URL em branco — o app sobe sem tentar conectar ao Postgres.

# PostgreSQL Railway (obrigatório para salvar dados)
DATABASE_URL=

# Whapi.cloud — token do canal WhatsApp
WHAPI_TOKEN=

# OpenAI — Whisper (transcrição) + GPT-4o-mini (análise de nota)
OPENAI_API_KEY=

# Seu número WhatsApp (ex: 5511999999999)
MY_WHATSAPP=

# Segredo para proteger endpoints /internal/cron/*
INTERNAL_CRON_SECRET=
